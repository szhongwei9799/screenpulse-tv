<?xml version="1.0" encoding="utf-8"?>
<!-- ScreenPulse TV Player - 设置页布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="48dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/settings_title"
        android:textColor="@color/text_primary"
        android:textSize="36sp"
        android:textStyle="bold" />

    <!-- Web 服务器信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@color/background_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="@string/settings_server"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/settings_server_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/primary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 播放模式设置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@color/background_card"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/settings_play_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/settings_play_mode"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <!-- 播放模式按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_mode_loop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/primary"
                android:focusable="true"
                android:text="@string/settings_mode_loop"
                android:textColor="@android:color/black" />

            <Button
                android:id="@+id/btn_mode_sequential"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="@color/background_elevated"
                android:focusable="true"
                android:text="@string/settings_mode_sequential"
                android:textColor="@color/text_secondary" />

            <Button
                android:id="@+id/btn_mode_random"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/background_elevated"
                android:focusable="true"
                android:text="@string/settings_mode_random"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- 播放列表信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@color/background_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:text="@string/error_empty_playlist"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/settings_playlist_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/success_green"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
